  "description": "VoteGuide AI — Offline-first civic intelligence platform powered by Google Gemini AI, deployed on Google Cloud Run. Empowers Indian citizens to understand elections, check eligibility, and vote with confidence.",
  "main": "server.js",
  "scripts": {
    "start":      "node server.js",
    "dev":        "NODE_ENV=development node server.js",
    "test":       "node --test tests/nlp.test.js tests/api.test.js",
    "test:unit":  "node --test tests/nlp.test.js",
    "test:api":   "node --test tests/api.test.js",
    "test:watch": "node --test --watch tests/",
    "lint":       "npx eslint server.js --max-warnings=0"
  },
  "keywords": [
    "civic-tech", "election", "voting", "democracy", "india",
    "google-cloud-run", "gemini-ai", "nlp", "accessibility",
    "hackathon", "express", "node"
  ],
  "author": {
