{
  "name": "voteguide-ai",
  "version": "4.0.0",
  "description": "VoteGuide AI — Enterprise Civic Intelligence Platform powered by Google Gemini 1.5 Flash with Real-time Search Grounding. Deployed on Google Cloud Run.",
  "main": "server.js",
  "scripts": {
    "start":      "node server.js",
    "dev":        "NODE_ENV=development node server.js",
    "test":       "node --test tests/nlp.test.js tests/api.test.js",
    "test:unit":  "node --test tests/nlp.test.js",
    "test:api":   "node --test tests/api.test.js",
    "lint":       "npx eslint server.js --max-warnings=0"
  },
  "keywords": [
    "google-cloud", "gemini-ai", "search-grounding", "cloud-run", "cloud-storage", 
    "cloud-logging", "civic-tech", "election", "india", "accessibility"
  ],
  "author": "Subho Saha",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google-cloud/logging": "^11.2.0",
    "@google-cloud/storage": "^7.7.0",
    "@google/generative-ai": "^0.24.0",
    "compression":           "^1.7.4",
    "cors":                  "^2.8.5",
    "express":               "^4.18.2",
    "express-rate-limit":    "^7.4.1",
    "helmet":                "^8.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  }
}
