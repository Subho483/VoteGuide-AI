    "url": "https://github.com/Subho483"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Subho483/VoteGuide-AI.git"
  },
  "homepage": "https://voteguide-ai-1047946370465.us-central1.run.app",
  "bugs": {
    "url": "https://github.com/Subho483/VoteGuide-AI/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "compression":           "^1.7.4",
    "cors":                  "^2.8.5",
