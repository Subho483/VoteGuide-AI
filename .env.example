# ============================================================
# VoteGuide AI — Environment Variables Template
# ============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# IMPORTANT: Never commit the actual .env file to git.
# For production (Cloud Run), inject these via:
#   gcloud run deploy --set-env-vars KEY=VALUE
# ============================================================

# Server Configuration
PORT=8080
NODE_ENV=development

# ── Future API Keys (not yet active) ──────────────────────
# Uncomment and populate when integrating live APIs.
# These are NEVER hardcoded in source code.

# Google Gemini API (for upgrading chatbot to live AI)
# GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps Platform (for server-side geocoding)
# GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ECI EPIC Card API (future booth lookup)
# ECI_API_KEY=your_eci_api_key_here

# ── Security ───────────────────────────────────────────────
# Session secret (if sessions are added in future)
# SESSION_SECRET=change_this_to_a_long_random_string

# ── Rate Limiting ──────────────────────────────────────────
# Requests per minute per IP on /api/chat
# RATE_LIMIT_RPM=30
