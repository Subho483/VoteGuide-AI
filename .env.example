# ============================================================
# VoteGuide AI — Environment Variable Template v3.0.0
# ============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# PRODUCTION (Google Cloud Run):
#   gcloud run deploy --set-env-vars KEY=VALUE
#
# ⚠️  Never commit the actual .env file to source control.
# ============================================================

# ── Server ────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Google Gemini AI (Primary Chat Engine) ────────────────
# Get yours at: https://aistudio.google.com/app/apikey
# When set, Gemini 1.5 Flash answers civic questions.
# When absent, the offline NLP engine handles all queries.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Future Integrations (not yet active) ──────────────────
# Google Maps Platform — server-side geocoding
# GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ECI EPIC Card API — real-time booth assignment lookup
# ECI_API_KEY=your_eci_api_key_here

# ── Rate Limiting (defaults configured in server.js) ──────
# Requests per minute per IP on /api/ routes (default: 30)
# RATE_LIMIT_RPM=30

# ── Security ───────────────────────────────────────────────
# Session secret for future auth (not currently used)
# SESSION_SECRET=change_this_to_a_long_random_string_min_32_chars
